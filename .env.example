# Digital Ocean GenAI Platform
# Obtenha sua chave em: cloud.digitalocean.com/gen-ai
OPENAI_API_KEY=your_digitalocean_api_key_here

# Neo4j Aura Free (gratuito em neo4j.com/cloud/aura)
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# LangSmith (opcional — para rastreamento e observabilidade)
# Obtenha sua chave em: smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=benchmark-knowledge-enhanced-rag
